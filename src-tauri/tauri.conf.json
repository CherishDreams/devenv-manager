{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "DevEnvManager",
  "version": "0.1.0",
  "identifier": "com.local.envmanager",
  "build": {
    "beforeDevCommand": "pnpm vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "环境管理",
        "width": 1320,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://asset.localhost; font-src 'self'; connect-src 'self' http://localhost:* https://*.tauri.app; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "portable"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    }
  }
}
